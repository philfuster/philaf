{
  "extends": "@philaf/tsconfig/node18-esm",
  "compilerOptions": {
    /* Modules */
    "baseUrl": "./" /* Specify the base directory to resolve non-relative module names. */,
    "types": ["node"]
  },
  "include": [
    "./.*.cjs", // root commonjs files
    "./*.js", // root javascript files
    "./.*.js" // root javascript config files
  ]
}
